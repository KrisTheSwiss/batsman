{
  "$schema": "https://railway.com/railway.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "aptPkgs": [
            "libglib2.0-0t64",
            "libnss3",
            "libnspr4",
            "libdbus-1-3",
            "libatk1.0-0t64",
            "libatk-bridge2.0-0t64",
            "libcups2t64",
            "libdrm2",
            "libx11-6",
            "libxcomposite1",
            "libxext6",
            "libxfixes3",
            "libxrandr2",
            "libgbm1",
            "libpango-1.0-0",
            "libxcb1",
            "libcairo2",
            "libasound2t64",
            "libxkbcommon0",
            "libatspi2.0-0t64",
            "libxdamage1"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "export PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=true && playwright install chromium && python script.py"
  }
}
